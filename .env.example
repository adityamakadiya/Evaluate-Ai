# ============================================================
# EvaluateAI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================


# ------------------------------------------------------------
# Supabase (Required)
# ------------------------------------------------------------
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public variants (used by browser-side Supabase client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...


# ------------------------------------------------------------
# AI Provider (Required — at least one)
# ------------------------------------------------------------
# Which AI provider to use for task extraction from meetings.
# Options: groq (default), gemini, anthropic
# If not set, defaults to "groq".
AI_PROVIDER=groq

# Groq (Default) — https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile          # Optional: override default model

# Google Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=AI...
# GEMINI_MODEL=gemini-2.0-flash-lite           # Optional: override default model

# Anthropic Claude — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001    # Optional: override default model


# ------------------------------------------------------------
# GitHub OAuth Integration (Required for GitHub features)
# ------------------------------------------------------------
# Create a GitHub OAuth App: https://github.com/settings/developers
# → OAuth Apps → New OAuth App
# Callback URL: https://yourdomain.com/api/integrations/github/callback
GITHUB_OAUTH_CLIENT_ID=your_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_oauth_client_secret

# Optional: Webhook secret for real-time events (if using org/repo webhooks)
# GITHUB_WEBHOOK_SECRET=your_random_webhook_secret


# ------------------------------------------------------------
# Fireflies.ai Integration (Optional)
# ------------------------------------------------------------
# API key is entered by managers in the dashboard UI, not here.
# This webhook secret is optional — for verifying webhook signatures.
# FIREFLIES_WEBHOOK_SECRET=your_webhook_secret


# ------------------------------------------------------------
# Cron Jobs (Optional)
# ------------------------------------------------------------
# Secret to protect cron API endpoints from unauthorized access.
# CRON_SECRET=your_random_cron_secret


# ------------------------------------------------------------
# NPM Publishing (CI only)
# ------------------------------------------------------------
# NPM_TOKEN=npm_...
